{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "resolveJsonModule": true
  },
  "include": ["smart_contracts/**/*.algo.ts", "deploy-config.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
